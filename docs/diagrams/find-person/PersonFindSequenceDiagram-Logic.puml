@startuml
!include ../style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":HitListParser" as HitListParser LOGIC_COLOR
participant "p:FindCommandParser" as FindCommandParser LOGIC_COLOR
participant "c:FindCommand" as FindCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":PersonMatchesFindPredicate" as Predicate MODEL_COLOR
participant ":Model" as Model MODEL_COLOR

end box

[-> LogicManager : execute("find Alex Lee")
activate LogicManager

LogicManager -> HitListParser : parseCommand("find Alex Lee")
activate HitListParser

create FindCommandParser
HitListParser -> FindCommandParser
activate FindCommandParser

FindCommandParser --> HitListParser
deactivate FindCommandParser

HitListParser -> FindCommandParser : parse("  Alex Lee")
activate FindCommandParser

create Predicate
FindCommandParser -> Predicate
activate Predicate

Predicate --> FindCommandParser
deactivate Predicate

create FindCommand
FindCommandParser -> FindCommand
activate FindCommand

FindCommand --> FindCommandParser : c
deactivate FindCommand

FindCommandParser --> HitListParser : c
deactivate FindCommandParser
FindCommandParser -[hidden]-> HitListParser
destroy FindCommandParser

HitListParser --> LogicManager : c
deactivate HitListParser

LogicManager -> FindCommand : execute()
activate FindCommand

FindCommand -> Model : updateFilteredPersonList(p)
activate Model

Model --> FindCommand
deactivate Model

FindCommand --> LogicManager : result
deactivate FindCommand
FindCommand -[hidden]-> LogicManager
destroy FindCommand


[<-- LogicManager
deactivate LogicManager
@enduml
