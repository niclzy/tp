@startuml person-add-execution
!include ../style.puml
skinparam ArrowFontStyle plain

skinparam shadowing false
skinparam ObjectFontColor #FFFFFF
skinparam ObjectAttributeFontColor #FFFFFF
skinparam ObjectBorderColor #FFFFFF

show objects
show members

object "<u>:LogicManager</u>" as LogicManager LOGIC_COLOR
object "<u>c:FindCommand</u>" as FindCommand LOGIC_COLOR
object "<u>:PersonMatchesFindPredicate</u>" as PersonMatchesFindPredicate MODEL_COLOR
object "<u>:ModelManager</u>" as ModelManager MODEL_COLOR

LogicManager --> FindCommand : executes >
FindCommand --> PersonMatchesFindPredicate : contains >
FindCommand ..> ModelManager

PersonMatchesFindPredicate : nameKeywords = ["Alex", "Lee"]
@enduml
