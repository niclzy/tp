@startuml group-add-activity-diagram /' Renames the file to kebab-case when exported as an image.'/
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12
start
:User executes command;

'Since the isValid parses everything, we can group it logically
if () then ([Command is valid])
    :Parse group name;
    :Create new Group object;

    if () then ([Group does not exist in HitList])
        :Add Group to Model;
        :Save updated HitList to Storage;
        :Display success message to User;
    else ([Group already exists])
        :Display duplicate group error;
    endif

else ([Command is invalid])
    :Display invalid command format error;
endif
stop
@enduml
