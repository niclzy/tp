@startuml role-add-sequence-diagram-logic /' Renames the file to kebab-case when exported as an image.'/'
!include ../style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":HitListParser" as HitListParser LOGIC_COLOR
participant ":AddCompanyRoleCommandParser" as AddCompanyRoleCommandParser LOGIC_COLOR
participant "cmd:AddCompanyRoleCommand" as AddCompanyRoleCommand LOGIC_COLOR
participant "result:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("roleadd /r software tester /d testing software /c Google")
activate LogicManager

LogicManager -> HitListParser : parseCommand("roleadd /r software tester /d testing software /c Google")
activate HitListParser

create AddCompanyRoleCommandParser
HitListParser -> AddCompanyRoleCommandParser
activate AddCompanyRoleCommandParser

AddCompanyRoleCommandParser --> HitListParser
deactivate AddCompanyRoleCommandParser

HitListParser -> AddCompanyRoleCommandParser : parse(" /r software tester /d testing software /c Google")
activate AddCompanyRoleCommandParser

create AddCompanyRoleCommand
AddCompanyRoleCommandParser -> AddCompanyRoleCommand
activate AddCompanyRoleCommand

AddCompanyRoleCommand --> AddCompanyRoleCommandParser : cmd
deactivate AddCompanyRoleCommand

AddCompanyRoleCommandParser --> HitListParser : cmd
deactivate AddCompanyRoleCommandParser
destroy AddCompanyRoleCommandParser

HitListParser --> LogicManager : cmd
deactivate HitListParser

LogicManager -> AddCompanyRoleCommand : execute(m)
activate AddCompanyRoleCommand

AddCompanyRoleCommand -> Model : addCompanyRole(companyName, role)
activate Model
Model --> AddCompanyRoleCommand
deactivate Model

AddCompanyRoleCommand -> Model : updateRoleList(companyName)
activate Model
Model --> AddCompanyRoleCommand
deactivate Model

create CommandResult
AddCompanyRoleCommand -> CommandResult
activate CommandResult

CommandResult --> AddCompanyRoleCommand : result
deactivate CommandResult

AddCompanyRoleCommand --> LogicManager : result
deactivate AddCompanyRoleCommand
destroy AddCompanyRoleCommand

[<--LogicManager
deactivate LogicManager
@enduml
