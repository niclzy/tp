@startuml list-sequence-diagram-logic /' Renames the file to kebab-case when exported as an image.'/
!include ../style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":HitListParser" as HitListParser LOGIC_COLOR
participant "l:ListCommand" as ListCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("list")
activate LogicManager

LogicManager -> HitListParser : parseCommand("list")
activate HitListParser

create ListCommand
HitListParser -> ListCommand : new ListCommand()
activate ListCommand

ListCommand --> HitListParser : l
deactivate ListCommand

HitListParser --> LogicManager : l
deactivate HitListParser

LogicManager -> ListCommand : execute(m)
activate ListCommand

ListCommand -> Model : updateFilteredPersonList(\nPREDICATE_SHOW_ALL_PERSONS)
activate Model

Model --> ListCommand
deactivate Model

create CommandResult
ListCommand -> CommandResult : new CommandResult(MESSAGE_SUCCESS)
activate CommandResult

CommandResult --> ListCommand : r
deactivate CommandResult

ListCommand --> LogicManager : r
deactivate ListCommand

[<--LogicManager
deactivate LogicManager
@enduml
