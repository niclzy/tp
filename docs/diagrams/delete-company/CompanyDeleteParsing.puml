@startuml
!include ../style.puml
skinparam ArrowFontStyle plain

skinparam shadowing false
skinparam ObjectFontColor #FFFFFF
skinparam ObjectAttributeFontColor #FFFFFF
skinparam ObjectBorderColor #FFFFFF

show objects
show members

object "<u>:HitListParser</u>" as HitListParser LOGIC_COLOR
object "<u>:DeleteCompanyCommandParser</u>" as DeleteCompanyCommandParser LOGIC_COLOR
object "<u>d:DeleteCompanyCommand</u>" as DeleteCompanyCommand LOGIC_COLOR

HitListParser ..> DeleteCompanyCommandParser : creates >
DeleteCompanyCommandParser ..> DeleteCompanyCommand : creates >

DeleteCompanyCommand : companyName = "Google"
@enduml
