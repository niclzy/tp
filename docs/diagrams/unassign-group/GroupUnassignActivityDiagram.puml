@startuml unassign-group/GroupUnassignActivityDiagram /' Renames the file to kebab-case when exported as an image.'/
!include ../style.puml

start
:User executes command;

:Parse contact name and group name;

if () then ([contact found])
    if () then ([group found])
        if () then ([contact in group])
            :Remove contact from group;
            :Display success message;
        else ([contact not in group])
            :Throw MESSAGE_PERSON_NOT_IN_GROUP;
        endif
    else ([group not found])
        :Throw MESSAGE_GROUP_NOT_FOUND;
    endif
else ([contact not found])
    :Throw MESSAGE_PERSON_NOT_FOUND;
endif

stop
@enduml
