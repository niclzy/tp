@startuml group-list-sequence-diagram-logic /' Renames the file to kebab-case when exported as an image.'/
!include ../style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":HitListParser" as HitListParser LOGIC_COLOR
participant ":ListGroupCommandParser" as ListGroupCommandParser LOGIC_COLOR
participant "l:ListGroupCommand" as ListGroupCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
participant "p:Predicate" as Predicate LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("grplist /g Students")
activate LogicManager

LogicManager -> HitListParser : parseCommand("grplist /g Students")
activate HitListParser

create ListGroupCommandParser
HitListParser -> ListGroupCommandParser
activate ListGroupCommandParser

ListGroupCommandParser --> HitListParser
deactivate ListGroupCommandParser

HitListParser -> ListGroupCommandParser : parse(" /g Students")
activate ListGroupCommandParser

create ListGroupCommand
ListGroupCommandParser -> ListGroupCommand
activate ListGroupCommand

ListGroupCommand --> ListGroupCommandParser : l
deactivate ListGroupCommand

ListGroupCommandParser --> HitListParser : l
deactivate ListGroupCommandParser
'Hidden arrow to position the destroy marker below the end of the activation bar.
ListGroupCommandParser -[hidden]-> HitListParser
destroy ListGroupCommandParser

HitListParser --> LogicManager : l
deactivate HitListParser

LogicManager -> ListGroupCommand : execute(m)
activate ListGroupCommand

ListGroupCommand -> Model : getGroup(toList)
activate Model

Model -> ListGroupCommand : group
deactivate Model

create Predicate
ListGroupCommand -> Predicate : group
activate Predicate

Predicate --> ListGroupCommand : p
deactivate Predicate

ListGroupCommand -> Model : updateFilteredPersonList(p)
activate Model

Model --> ListGroupCommand
deactivate Model

create CommandResult
ListGroupCommand -> CommandResult
activate CommandResult

CommandResult --> ListGroupCommand : r
deactivate CommandResult

ListGroupCommand --> LogicManager : r
deactivate ListGroupCommand

[<--LogicManager
deactivate LogicManager
@enduml
